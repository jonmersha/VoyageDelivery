rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, displayName, email, photoURL, rating, createdAt
    //
    // Collection: trips
    // Fields: travelerId, travelerName, origin, destination, travelDate, capacity, itemTypes, status, createdAt
    //
    // Collection: requests
    // Fields: requesterId, requesterName, itemName, itemDescription, origin, destination, deadline, commission, status, createdAt
    //
    // ===============================================================

    // --- Helper Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "jonmersha@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 500));
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['travelerId', 'origin', 'destination', 'travelDate', 'status']) &&
             data.travelerId == request.auth.uid &&
             data.origin is string && data.origin.size() > 0 && data.origin.size() < 100 &&
             data.destination is string && data.destination.size() > 0 && data.destination.size() < 100 &&
             data.status in ['active', 'completed', 'cancelled'];
    }

    function isValidRequest(data) {
      return data.keys().hasAll(['requesterId', 'itemName', 'origin', 'destination', 'status', 'commission']) &&
             data.requesterId == request.auth.uid &&
             data.itemName is string && data.itemName.size() > 0 && data.itemName.size() < 100 &&
             data.origin is string && data.origin.size() > 0 && data.origin.size() < 100 &&
             data.destination is string && data.destination.size() > 0 && data.destination.size() < 100 &&
             data.commission is number && data.commission >= 0 &&
             data.status in ['pending', 'matched', 'in-transit', 'delivered', 'cancelled'];
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data)) || isAdmin();
    }

    match /trips/{tripId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTrip(request.resource.data);
      allow update: if (isAuthenticated() && resource.data.travelerId == request.auth.uid && isValidTrip(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidRequest(request.resource.data);
      allow update: if (isAuthenticated() && resource.data.requesterId == request.auth.uid && isValidRequest(request.resource.data)) || isAdmin();
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
